# SportsDash environment. Copy to .env:   cp .env.example .env
#
# These values are consumed by docker-compose and forwarded to the api
# container. In local development (no Docker) the backend reads
# SPORTSDASH_* environment variables directly (a backend/.env file also
# works via pydantic-settings).

# IANA timezone used for "today", local calendar-day boundaries, and the
# daily refresh hour. All storage stays UTC regardless of this setting.
SPORTSDASH_TIMEZONE=America/New_York

# ntfy topic that game notifications are published to. Subscribe to this
# topic in the ntfy mobile app, pointed at your server (http://<host>:8090).
# Pick something hard to guess if your ntfy port is reachable from outside.
SPORTSDASH_NTFY_TOPIC=sportsdash
